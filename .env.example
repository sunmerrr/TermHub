# TermHub 환경변수 예시

# 대시보드 포트 (기본값: 8081)
PORT=8081

# 대시보드 비밀번호 (반드시 변경할 것)
DASHBOARD_PASSWORD=changeme

# Discord 알림 웹훅 (선택)
DISCORD_WEBHOOK=

# Discord 경고 알림 웹훅 (선택, 미설정 시 DISCORD_WEBHOOK 사용)
DISCORD_ALERT_WEBHOOK=

# 터널 헬스체크 활성화 (1로 설정 시 60초마다 터널 상태 확인)
ENABLE_TUNNEL_HEALTHCHECK=0

# ── 미리보기 탭 기능 ──────────────────────────────────
# 터미널 로그에서 localhost:XXXX 패턴 감지 시 미리보기 탭 자동 생성
ENABLE_PREVIEW=1

# 포트 감지 시 cloudflared 터널 자동 생성 (원격 접근용)
# cloudflared가 PATH에 설치되어 있어야 합니다.
# 설치: https://developers.cloudflare.com/cloudflare-one/connections/connect-networks/downloads/
PREVIEW_TUNNEL=0
